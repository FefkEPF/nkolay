# SMTP Settings (SERVER-SIDE ONLY - never sent from the browser)
# These are read exclusively by the server from environment variables.
# The client never submits SMTP credentials; if unset, inquiries are logged server-side.
# REQUIRED for production email sending:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=
SMTP_SECURE=false

# ─── Server Configuration ──────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Vite Configuration ─────────────────────────────────
# Set to "true" to disable HMR (Hot Module Replacement) during development
DISABLE_HMR=false

# ─── Frontend URLs (used for SEO and social sharing) ──────
VITE_SITE_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

